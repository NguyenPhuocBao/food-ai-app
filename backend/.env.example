DATABASE_URL=postgresql://admin:admin123@localhost:5432/food_app_db
AI_API_URL=http://localhost:8000
# auto: local dev calls AI_API_URL or localhost:8000, production disables scan if AI_API_URL is empty.
# disabled: deployed demo returns manual food-picking fallback instead of calling an AI model.
# remote: set AI_API_URL to a reachable hosted AI service.
AI_SCAN_MODE=auto
JWT_SECRET=replace-with-a-strong-secret
PORT=5000
NODE_ENV=development

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_CANDIDATES=gemini-2.0-flash,gemini-2.5-flash
GEMINI_API_VERSIONS=v1,v1beta

CHAT_AI_PROVIDER=auto
XAI_BASE_URL=https://api.x.ai/v1
XAI_API_KEY=
XAI_MODEL=grok-4.20-beta-latest-non-reasoning
CHAT_HISTORY_LIMIT=8

MEAL_REMINDER_ENABLED=true
MEAL_REMINDER_INTERVAL_MS=60000
BREAKFAST_REMINDER_AT=08:00
LUNCH_REMINDER_AT=12:00
DINNER_REMINDER_AT=19:00
NO_MEAL_EMAIL_AT=20:30

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
RESET_PASSWORD_TOKEN_EXPIRES_MINUTES=15
